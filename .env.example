# =============================================================
# .env.example - 宅建OS v2.0 Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your values.
# DO NOT commit your .env file to version control.
# This application runs entirely in the browser (IndexedDB)
# and does not require any API keys for core functionality.
# =============================================================

# Application Mode
VITE_APP_MODE=production

# Enable development-only preview features (default: false in production)
VITE_ENABLE_DEV_PREVIEW=false

# Optional: Base URL for any external API (leave empty if not used)
VITE_API_BASE_URL=

# Optional: Application version tag (auto-detected from package.json if omitted)
VITE_APP_VERSION=
