  "quality_design": {
    "quality_A": {
      "requirements": [
        "問題文固有の語句を3語以上使用",
        "application_to_question が80文字以上",
        "correct_answer_reason または why_this_answer が80文字以上",
        "why_user_wrong が40文字以上",
        "source_refs が1件以上",
        "source_refs が結論と直接対応",
        "generic_template_detected = false",
        "label_conflict_suspected = false",
        "human_review_required = false"
      ],
      "review_status": "auto_ok",
      "ready_for_import": true
    },
    "quality_B": {
      "requirements": [
        "大筋正しいが、根拠・当てはめ・why_user_wrong の一部が弱い",
        "問題文固有の語句が1〜2語",
        "application_to_question が50〜79文字",
        "why_user_wrong が20〜39文字"
      ],
      "review_status": "draft または human_review_required",
      "ready_for_import": false,
      "action": "修正または追加生成"
    },
    "quality_C": {
      "triggers": [
        "汎用文中心",
        "条文番号誤り",
        "法令解釈誤り",
        "source_refsと結論が不一致",
        "正誤ラベル疑義あり",
        "source_refsなしでauto_ok",
        "民間サイトだけでauto_ok"
      ],
      "review_status": "human_review_required",
      "ready_for_import": false,
      "action": "要修正・再生成"
    }
  },
  "review_status_design": {
    "auto_ok": {
      "conditions": [
        "quality_A",
        "source_refsが1件以上で一次法令",
        "label_conflict_suspected = false",
        "human_review_required = false"
      ]
    },
    "human_review_required": {
      "conditions": [
        "quality_C",
        "label_conflict_suspected = true",
        "source_refsなし",
        "条文番号誤り疑い",
        "法令解釈誤り疑い"
      ]
    },
    "draft": {
      "conditions": [
        "quality_B",
        "根拠不十分",
        "当てはめ不足"
      ]
    }
  },
  "field_design": {
    "trap_detected": {
      "definition": "選択肢にtrapキーワードが含まれているか（正誤とは無関係）",
      "examples": [
        "農地法3条 + 届出",
        "媒介契約種類混同",
        "35条/37条混同"
      ],
      "note": "trap_detected = true は必ずしも誤りを意味しない。正しい選択肢でもtrapキーワードを含む場合がある。"
    },
    "label_conflict_suspected": {
      "definition": "is_statement_trueと法的結論が矛盾している可能性",
      "trigger_condition": "is_statement_true = true だが、法令解釈上は誤りである、またはその逆",
      "severity": "HIGH",
      "action": "label_conflict_suspected = true の場合、human_review_required = true にする"
    }
  },
