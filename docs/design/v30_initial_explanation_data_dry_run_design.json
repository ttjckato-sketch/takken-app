    "quality_A": {
      "source_trace_grade": "A",
      "confidence": "high",
      "source_refs_min": 1,
      "source_refs_primary": ["e_gov", "mlit", "moj", "maff"],
      "application_min_length": 30,
      "why_min_length": 30,
      "label_conflict_suspected": false,
      "human_review_required": false,
      "review_status": "auto_ok"
    },
    "quality_B": {
      "source_trace_grade": "B",
