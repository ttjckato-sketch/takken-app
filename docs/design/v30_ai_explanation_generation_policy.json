      },
      {
        "value": "trap_points",
        "target_field": "question/choice",
        "description": "ひっかけポイント"
      }
    ],
    "alignment_check": {
      "verification_logic": [
        "source_refsに含まれるlaw_nameが解説文に言及されている",
        "source_refsに含まれるarticleが解説文に引用されている",
        "supports_fieldで指定されたフィールドに根拠が反映されている"
      ],
      "pass_conditions": [
        "source_refsのlaw_nameが解説文に1回以上言及されている",
        "source_refsのarticleが解説文に引用されている",
        "supports_fieldで指定されたフィールドに根拠が反映されている"
      ]
    }
  },
  "review_design": {
    "auto_ok_conditions": {
      "all_required": true,
      "conditions": [
        {
          "field": "source_trace_grade",
          "operator": "=",
          "value": "A",
          "description": "根拠等級"
        },
        {
          "field": "source_refs_count",
          "operator": ">=",
          "value": 1,
          "description": "一次法令の件数"
        },
        {
          "field": "source_refs_alignment",
          "operator": "=",
          "value": "all_supported",
          "description": "根拠と解説の対応"
        },
        {
          "field": "problem_specificity",
          "operator": "=",
          "value": "concrete",
          "description": "問題文固有の当てはめ"
        },
        {
          "field": "why_user_wrong_concrete",
          "operator": ">=",
          "value": 30,
          "description": "誤答理由の具体性"
        },
        {
          "field": "label_conflict_suspected",
          "operator": "=",
          "value": false,
          "description": "正誤ラベル疑義"
        },
        {
          "field": "human_review_required",
          "operator": "=",
          "value": false,
          "description": "人的レビュー要"
        },
        {
          "field": "confidence",
          "operator": "=",
          "value": "high",
          "description": "確信度"
        }
      ]
    },
    "human_review_required_conditions": {
      "any_required": true,
      "conditions": [
        {
          "condition": "正誤ラベル疑義",
          "field": "label_conflict_suspected",
          "operator": "=",
          "value": true
        },
        {
          "condition": "根拠が弱い",
          "field": "source_trace_grade",
          "operator": "in",
          "value": ["C", "D"]
        },
        {
          "condition": "条文だけでは判断が難しい",
          "description": "判例・通達・実務運用が絡む"
        },
        {
          "condition": "古い過去問",
          "description": "現行法とのズレがあり得る"
        },
        {
          "condition": "AI生成の確信度が低い",
          "field": "confidence",
          "operator": "in",
          "value": ["medium", "low"]
        },
        {
          "condition": "source_refs_alignmentが弱い",
          "description": "一部のsupports_fieldに対応がない"
        }
      ]
    },
    "draft_conditions": {
      "description": "auto_okとhuman_review_requiredの中間",
      "conditions": [
        {
          "condition": "source_trace_grade",
          "operator": "=",
          "value": "B"
        },
        {
          "condition": "一部のフィールドが弱い",
          "description": "why_user_wrongが短い等"
        },
        {
          "condition": "source_refs_alignmentが一部弱い",
          "description": "一部のsupports_fieldに対応がない"
        }
      ]
    },
    "rejected_conditions": {
      "conditions": [
        {
          "condition": "明らかな誤り",
          "description": "法令の解釈が誤っている"
        },
        {
          "condition": "品質基準を満たさない",
          "description": "汎用テンプレートのみ等"
        }
      ]
    }
  },
  "label_conflict_design": {
    "detection_patterns": [
      {
        "pattern": "正誤と根拠条文の矛盾",
        "description": "問題文の正誤と根拠条文が矛盾する可能性",
        "detection_logic": "条文の要件と問題文の事実が対応しない"
      },
      {
