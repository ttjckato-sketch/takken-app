      },
      {
        "field": "note",
        "type": "string",
        "required": false,
        "description": "備考"
      }
    ],
    "supports_field_values": [
      {
        "value": "applicable_rule",
        "target_field": "question_explanations",
        "description": "適用されるルール"
      },
      {
        "value": "correct_answer_reason",
        "target_field": "choice_explanations",
        "description": "正解の理由"
      },
      {
        "value": "application_to_question",
        "target_field": "question_explanations",
        "description": "問題文への当てはめ"
      },
      {
        "value": "application_to_statement",
        "target_field": "choice_explanations",
