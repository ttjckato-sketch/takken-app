      },
      {
        "pattern": "詐欺と強迫の取り違え",
        "description": "第三者対抗の取り違え",
        "detection_logic": "取消期間の取り違え"
      },
      {
        "pattern": "借地借家法の取り違え",
        "description": "普通借家・定期借家の取り違え",
        "detection_logic": "更新の有無の取り違え"
      },
      {
        "pattern": "is_statement_true_snapshot",
        "description": "is_statement_trueがnull",
        "detection_logic": "明示的に疑義あり"
      }
    ],
    "handling": {
      "important": "is_statement_trueは絶対に変更しない",
      "actions": [
        "label_conflict_suspected = true とする",
        "human_review_required = true とする",
        "review_status = 'label_conflict_suspected' とする",
        "noteに疑義の内容を記録する"
      ]
    }
  },
