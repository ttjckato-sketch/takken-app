    "selection_criteria": [
      "法令根拠が明確: 条文・通達で根拠が特定できる",
      "正誤ラベル安定: is_statement_trueの信頼性が高い",
      "解説の具体性: 問題文固有の事実関係がある",
      "頻出分野: 過去問での出題頻度が高い"
    ]
  },
