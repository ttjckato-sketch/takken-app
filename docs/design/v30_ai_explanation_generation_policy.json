  "quality_rules": {
    "prohibited_patterns": [
      {
        "pattern": "汎用テンプレートのみ",
        "example": "法令の規定に関する正誤判断です",
        "reason": "問題文に即していない"
      },
      {
        "pattern": "抽象的指示のみ",
        "example": "基本ルールを確認しましょう",
        "reason": "具体的な当てはめがない"
      },
      {
        "pattern": "事実列挙のみ",
        "example": "問題文の事実を整理しましょう",
        "reason": "法的評価がない"
      },
      {
        "pattern": "問題文固有語句なし",
        "example": "カテゴリ名のみの解説",
        "reason": "具体性に欠ける"
      },
      {
        "pattern": "正誤理由なし",
        "example": "正解は〇ですのみ",
        "reason": "根拠が不明"
      },
      {
        "pattern": "why_user_wrongなし",
        "example": "誤答者の誤解を説明しない",
        "reason": "学習効果が低い"
      },
      {
        "pattern": "source_refsなしのauto_ok",
        "example": "根拠なしで高品質判定",
        "reason": "信頼性が低い"
      },
      {
        "pattern": "AI推測のみのauto_ok",
        "example": "推論のみで確定",
        "reason": "検証不可能"
      },
      {
        "pattern": "民間サイトのみのauto_ok",
        "example": "信頼性が一次法令に劣る",
        "reason": "根拠が弱い"
      }
    ],
    "required_conditions": [
      {
        "condition": "問題文固有の語句",
        "description": "問題文・選択肢文から抽出した語句を含む",
        "threshold": "3語以上"
      },
      {
        "condition": "具体的な当てはめ",
        "description": "事実と要件の具体的な対応",
        "threshold": "80文字以上"
      },
      {
        "condition": "明確な正誤理由",
        "description": "なぜ〇/×かの法的根拠",
        "threshold": "40文字以上"
      },
      {
        "condition": "具体的な誤答理由",
        "description": "誤答者が陥る典型的な誤解",
        "threshold": "30文字以上"
      },
      {
        "condition": "一次法令の根拠",
        "description": "e-Gov等の一次法令を引用",
        "threshold": "1件以上"
      }
    ],
    "quality_checklist": [
      "question_focusに問題文固有の語句が含まれる",
      "facts_summaryに問題文の具体的事実が列挙されている",
      "application_to_questionに事実と要件の対応が記述されている",
      "why_this_answerに法的根拠と当てはめが記述されている",
      "why_user_wrongに誤答者の典型的な誤解が記述されている",
      "source_refsに一次法令が含まれている",
      "source_refsのsupports_fieldで対応関係が明示されている",
      "trap_pointsに問題文固有のひっかけが含まれている"
    ]
  },
